# Telegram Bot token (від @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRstuVWxyZ

# Together AI API key (https://api.together.ai)
TOGETHER_API_KEY=your_together_key_here

# AI model (Together AI)
# Рекомендовано: meta-llama/Llama-3.3-70B-Instruct-Turbo (швидкий, укр, JSON mode)
# Альтернативи:
#   - deepseek-ai/DeepSeek-V3
#   - Qwen/Qwen2.5-72B-Instruct-Turbo
#   - meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
AI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Postgres
POSTGRES_PASSWORD=postgres

# Telegram ID адміна (куди слати критичні alerts)
# Дізнатись свій ID: надіслати /start боту @userinfobot
ADMIN_TELEGRAM_ID=123456789

# URL зображення для меню (всі опційні — якщо не задано, буде text-only)
MENU_PHOTO_URL=https://i.ibb.co/8DCXzgMp/main.webp
MENU_PHOTO_LIST=
MENU_PHOTO_UPCOMING=
MENU_PHOTO_HELP=
